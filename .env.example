# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
APP_NAME=AuraAPI
APP_VERSION=0.1.0
# Set to true to enable FastAPI debug mode and auto-reload
DEBUG=false
# One of: development, staging, production
ENVIRONMENT=development

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# Async PostgreSQL URL — must use asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aura_api

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
# Set to true to echo all SQL statements (useful for debugging)
DB_ECHO=false

# ──────────────────────────────────────────────
# Security — JWT
# ──────────────────────────────────────────────
# Required at runtime for any auth flow — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# May be left blank when running alembic migrations only.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────
# Security — Default admin user (seeded on startup if no admin exists)
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@aura.local
ADMIN_USERNAME=admin
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
# Set a strong password for the seeded admin account.
# If left blank, admin seeding is skipped (server still boots; useful for migrations).
ADMIN_PASSWORD=

# ──────────────────────────────────────────────
# Security — Password hashing
# ──────────────────────────────────────────────
# Bcrypt cost factor — higher = slower hashing, more brute-force resistance.
BCRYPT_ROUNDS=12

# ──────────────────────────────────────────────
# Security — Token cleanup
# ──────────────────────────────────────────────
# How often (in seconds) the background task purges expired tokens
TOKEN_CLEANUP_INTERVAL_SECONDS=3600

# ──────────────────────────────────────────────
# Security — Chrome extension install tokens
# ──────────────────────────────────────────────
# Lifetime of issued install tokens (opaque random strings, SHA-256 hashed
# at rest). The extension silently renews within 5 days of expiry.
EXTENSION_TOKEN_EXPIRE_DAYS=30
# How often (in seconds) the background task purges expired install tokens.
EXTENSION_TOKEN_CLEANUP_INTERVAL_SECONDS=3600

# ──────────────────────────────────────────────
# Server — CORS
# ──────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Note: cannot include "*" if CORS_ALLOW_CREDENTIALS=true (browser CORS spec).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
# Comma-separated list of allowed HTTP methods, or * for all
CORS_ALLOW_METHODS=*
# Comma-separated list of allowed headers, or * for all
CORS_ALLOW_HEADERS=*

# ──────────────────────────────────────────────
# Server — Rate limiting (slowapi)
# ──────────────────────────────────────────────
# Set to false to disable rate limiting entirely (e.g. for tests).
RATE_LIMIT_ENABLED=true
# Format: "{count}/{period}" — period is one of second/minute/hour/day.
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_REFRESH=10/minute
# Single-email prediction endpoint (POST /api/v1/analysis/predict).
RATE_LIMIT_PREDICT=60/minute
# Batch prediction endpoint (POST /api/v1/analysis/predict/batch).
RATE_LIMIT_PREDICT_BATCH=10/minute
# Chrome extension surface — IP-keyed for register/renew, install-hash-keyed
# for predict. Values are shared verbatim across both backends.
RATE_LIMIT_EXTENSION_REGISTER=3/minute
RATE_LIMIT_EXTENSION_RENEW=10/minute
RATE_LIMIT_EXTENSION_PREDICT=60/minute

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Path to the log file (directory will be created if it does not exist)
LOG_FILE_PATH=logs/app.log

# ──────────────────────────────────────────────
# Inference — model registry & detector
# ──────────────────────────────────────────────
# Root directory holding versioned model artefacts (subject/body vectorisers,
# classifier, optional calibrator, active-version pointer).
AURA_MODELS_DIR=./models
# Optional override for the calibrator artefact path. Leave blank to use the
# calibrator shipped alongside the active version in the registry.
AURA_CALIBRATOR_PATH=
# Default decision threshold used when a request does not supply one.
AURA_DECISION_THRESHOLD=0.75
# Chrome extension `should_alert` cutoff — phishing_probability >= this
# AND predicted_label == "SPAM" trips the HIGH-risk popover.
AURA_ALERT_THRESHOLD=0.90
# Hard cap on the projected (text or HTML-stripped) body bytes a single
# /api/v1/emails/analyze call may carry. Exceed → 400 BAD_REQUEST.
AURA_EMAIL_MAX_BODY_BYTES=102400

# ──────────────────────────────────────────────
# Inference — review zone thresholds
# ──────────────────────────────────────────────
# prob < low → NOT_SPAM; low ≤ prob < high → REVIEW; prob ≥ high → SPAM.
AURA_REVIEW_LOW=0.3
AURA_REVIEW_HIGH=0.8

# ──────────────────────────────────────────────
# Inference — drift monitor
# ──────────────────────────────────────────────
# Append-only JSONL log of predictions + confirmations.
AURA_DRIFT_LOG=./logs/drift.jsonl
# False-positive-rate threshold that raises a DEGRADED drift signal.
AURA_DRIFT_FPR_THRESHOLD=0.10

# ──────────────────────────────────────────────
# Inference — auto-reviewer (optional LLM decision support)
# ──────────────────────────────────────────────
# One of: groq, google. Leave blank to disable auto-review endpoints.
AURA_REVIEW_PROVIDER=
# Provider API key. Required when AURA_REVIEW_PROVIDER is set.
AURA_REVIEW_API_KEY=
# Optional model-name override; blank uses the provider's default.
AURA_REVIEW_MODEL=
AURA_REVIEW_TIMEOUT=30.0
AURA_REVIEW_MAX_RETRIES=2
# Phase 12 — short-TTL LRU cache for repeat auto-review calls on the same
# (sender, subject, body, model_name). Only successful verdicts are cached;
# transient upstream errors always re-call the provider. Disabled by default.
AURA_REVIEW_CACHE_ENABLED=false
AURA_REVIEW_CACHE_TTL=600
AURA_REVIEW_CACHE_MAX=256

# ──────────────────────────────────────────────
# Inference — batch predict
# ──────────────────────────────────────────────
# Hard cap on emails per /predict/batch call.
AURA_BATCH_MAX=500

# ──────────────────────────────────────────────
# Inference — shadow predictions (Phase 12)
# ──────────────────────────────────────────────
# When enabled, each activate() keeps the prior detector alive for `days` so
# /predict also records the shadow version's output (shadow_* columns on
# prediction_events). The shadow verdict is never acted on — it never feeds
# drift, never enqueues review, never feeds the training buffer.
AURA_SHADOW_ENABLED=false
AURA_SHADOW_DAYS=7

# ──────────────────────────────────────────────
# Inference — explain top-k (Phase 12)
# ──────────────────────────────────────────────
# When enabled, /predictions/{id}/explain adds a top-k TF-IDF term list
# derived from the active detector's vectorisers and classifier weights.
# No re-prediction — the persisted label/probability is authoritative.
AURA_EXPLAIN_TOPK_ENABLED=false
AURA_EXPLAIN_TOPK=10

# ──────────────────────────────────────────────
# Inference — upload hardening (Phase 12)
# ──────────────────────────────────────────────
# Require HMAC-SHA256 signatures on model uploads. The header value is the
# HMAC of the uploaded SHA-256 hex digest using AURA_UPLOAD_HMAC_SECRET.
AURA_UPLOAD_REQUIRE_SIGNATURE=false
AURA_UPLOAD_HMAC_SECRET=
# Pickle sandbox — unpickle uploads in a short-lived subprocess with an
# import-graph smoke check so a malicious payload cannot touch the API
# process state.
AURA_UPLOAD_PICKLE_SANDBOX=false
AURA_UPLOAD_PICKLE_SANDBOX_TIMEOUT=15.0

# ──────────────────────────────────────────────
# Training — unlock thresholds & holdout
# ──────────────────────────────────────────────
# Minimum total buffer size before training unlocks.
TRAINING_MIN_BATCH=200
# Minimum count of each class required before training unlocks.
TRAINING_MIN_PER_CLASS=10
# Maximum class-imbalance delta tolerated before training unlocks. When the
# minority share of the buffer is below (0.5 - delta) the buffer is considered
# too imbalanced and the status endpoint reports a blocker.
TRAINING_BALANCE_DELTA=0.4
# Directory holding the labelled holdout set used to compute performance_before/after
# on every training run (required to avoid the §2.7 silent-skip promotion guard).
AURA_HOLDOUT_DIR=./models/holdout
# Hard caps on CSV uploads to /api/v1/training/buffer/import. Files exceeding
# the byte cap are rejected with 413 before parsing; the row cap aborts
# parsing once exceeded and rolls back the partial import.
TRAINING_CSV_MAX_BYTES=52428800
TRAINING_CSV_MAX_ROWS=50000
# Hard cap on partial_fit iterations per OnlineLearner call — NOTEBOOK_CONTRACT
# §3.2 caps iterations to prevent runaway online-learning loops.
TRAINING_MAX_ITER_PER_CALL=15

# ──────────────────────────────────────────────
# Training — buffer quality gate (Phase 12)
# ──────────────────────────────────────────────
# When enabled, items with combined (subject + body) out-of-vocabulary rate
# above the threshold are rejected at enqueue and on CSV import. Uses the
# active detector's vectorisers — no gate runs when no detector is loaded.
TRAINING_QUALITY_GATE_ENABLED=false
TRAINING_QUALITY_GATE_MAX_OOV=0.8

# ──────────────────────────────────────────────
# Review — queue behaviour
# ──────────────────────────────────────────────
# How unassigned review items are distributed. One of: round_robin.
REVIEW_ASSIGNMENT=round_robin
# Hard cap on analyst-triggered manual auto-review batches.
REVIEW_AUTO_BATCH_MAX=5
# SLA threshold (in seconds) for review-queue health stats on the dashboards.
# Pending items older than this are counted as "breached". Default is 24h.
REVIEW_SLA_SECONDS=86400

# ──────────────────────────────────────────────
# Review — rejection sampler (Phase 12)
# ──────────────────────────────────────────────
# When enabled and sample_rate < 1.0, non-sampled REVIEW-zone enqueues are
# auto-resolved rather than landing in the analyst queue. policy=auto_confirm
# picks the verdict by probability (>= 0.5 → PHISHING); policy=defer parks
# the item as DEFERRED for later triage.
REVIEW_REJECTION_SAMPLER_ENABLED=false
REVIEW_REJECTION_SAMPLER_RATE=1.0
REVIEW_REJECTION_SAMPLER_POLICY=auto_confirm

# ──────────────────────────────────────────────
# Review — reviewer agreement log (Phase 12)
# ──────────────────────────────────────────────
# When enabled, admin resolutions of escalations whose analyst recorded a
# tentativeLabel different from the admin verdict write a review_disagreements
# row for audit.
REVIEW_DISAGREEMENT_LOG_ENABLED=false

# ──────────────────────────────────────────────
# Benchmark — dataset uploads & run limits
# ──────────────────────────────────────────────
# Hard caps on CSV uploads to /api/v1/benchmarks/datasets. Mirrors the buffer
# import surface — oversize files 413 before parsing, the row cap aborts
# ingestion once exceeded.
BENCHMARK_CSV_MAX_BYTES=52428800
BENCHMARK_CSV_MAX_ROWS=50000
# Upper bound on versions per run so a single request can't spin up an
# unbounded number of per-version loads.
BENCHMARK_MAX_VERSIONS_PER_RUN=10
# Bin count for the expected-calibration-error computation.
BENCHMARK_ECE_NUM_BINS=10

# ──────────────────────────────────────────────
# Server-Sent Events (SSE)
# ──────────────────────────────────────────────
# Heartbeat tick used by the broker. Also bounds disconnect-detection latency:
# a dead client is unsubscribed within ~one heartbeat.
SSE_HEARTBEAT_SECONDS=15.0
# Per-subscriber queue cap. Slow consumers drop their oldest events rather
# than stalling the broker fan-out for everyone else.
SSE_SUBSCRIBER_QUEUE_MAX=256
# Per-topic ring buffer for Last-Event-ID replay on resubscribe. 0 disables
# replay (broker becomes pure fan-out).
SSE_REPLAY_WINDOW_SIZE=128
# Internal /api/v1/system/sse-echo smoke endpoint — leave off in production.
SSE_ECHO_ENABLED=false

# ──────────────────────────────────────────────
# Chrome extension — origins, allow/block lists, OAuth
# ──────────────────────────────────────────────
# Extra HTTP origins the extension surface accepts (concatenated with
# CORS_ORIGINS at startup). The chrome-extension://<id> origin is matched
# via allow_origin_regex and does NOT need to be listed here.
EXTENSION_CORS_ORIGINS=https://mail.google.com
# Comma-separated allow-lists. Empty = open to all Google accounts.
# Domains match by suffix (case-insensitive); emails match exactly.
EXTENSION_ALLOWLIST_DOMAINS=
EXTENSION_ALLOWLIST_EMAILS=
# Comma-separated block-lists, applied AFTER the allow-list check. Blocks
# take precedence — a blocked email is rejected even if its domain is allowed.
EXTENSION_BLOCKLIST_DOMAINS=
EXTENSION_BLOCKLIST_EMAILS=
# Optional Google OAuth client id. When set, the tokeninfo audience is
# verified to equal this value; blank skips the audience check.
EXTENSION_GOOGLE_OAUTH_CLIENT_ID=
